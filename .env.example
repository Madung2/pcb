# ──────────────────────────────────────
# GPS SMART KIOSK 통신 모듈 설정
# 이 파일을 복사해서 .env 로 저장하세요
# ──────────────────────────────────────

# 백엔드에서 키오스크 구분 (WebSocket PERSON_DETECTED 등)
KIOSK_ID=

# 장치별 base_url / led_url / meet_url 조회 API
DEVICE_API_BASE_URL=https://hcg.jdone.co.kr
DEVICE_API_TIMEOUT=10.0

# 시리얼 포트 설정
SERIAL_PORT=COM8
SERIAL_BAUDRATE=115200
SERIAL_PORT_DESCRIPTION_KEYWORD=USB
# 리부트 후 COM 번호가 바뀌어도 동일 USB 장치를 찾을 때 사용 (GUI 연결 시 자동 저장)
# SERIAL_USB_VID=10C4
# SERIAL_USB_PID=EA60
# SERIAL_USB_SERIAL=

# WebSocket 브릿지 (백엔드 제어 수신 등, true 일 때만 연결)
# URL 은 WEBVIEW_WS_URL 또는 레거시 WS_URL 사용.
WS_ENABLED=false
WS_URL=
WS_RECONNECT_INTERVAL=5.0

# 통합 WebView 모드 (Windows 전용)
WEBVIEW_ENABLED=false
WEBVIEW_WS_URL=
WEBVIEW_WS_KIOSK_ID=
WEBVIEW_DEVTOOLS=false
WEBVIEW_TRAY_ENABLED=true

# 사람 없음 + 입력 유휴 시 자동 도어 닫기 (초, INPUT_MONITOR_ENABLED 필요)
VACANT_IDLE_CLOSE_SECONDS=20.0

INPUT_MONITOR_ENABLED=true

# PCB status 조회 주기 (초). 600 = 10분
STATUS_POLL_INTERVAL=600

# 오른쪽 버튼 Meet/웹 브라우저
# Meet URL은 서버 WebSocket 메시지로 수신
KIOSK_BROWSER_CMD=
BACKGROUND_BROWSER_TIMEOUT_SECONDS=300

# Windows: 별도 COM·보드레이트에서 U/D 문자로 OS 마스터 볼륨 (PCB용 SERIAL_* 와 분리)
VOLUME_SERIAL_ENABLED=false
VOLUME_SERIAL_PORT=COM5
VOLUME_BAUDRATE=38400
# 구 설정 호환용 (비우면 VOLUME_BAUDRATE만 쓰면 됨)
# VOLUME_SERIAL_BAUDRATE=
VOLUME_SERIAL_TIMEOUT=0.2
# 비우면 U·D 문자만 처리. 바이너리 장치는 콤마 구분 hex(소문자) 예: 1c,fc
# VOLUME_UP_HEX_CODES=
# VOLUME_DOWN_HEX_CODES=

# 로그 레벨 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
