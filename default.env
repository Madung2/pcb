# ──────────────────────────────────────
# GPS SMART KIOSK 통신 모듈 설정
# 이 파일을 복사해서 .env 로 저장하세요
# ──────────────────────────────────────

# 백엔드에서 키오스크 구분 (WebSocket PERSON_DETECTED 등)
KIOSK_ID=0a5066aa-20cf-4129-8e33-e45bc5e23676

# 장치별 base_url / led_url / meet_url 조회 API
DEVICE_API_BASE_URL=https://hcg.jdone.co.kr
DEVICE_API_TIMEOUT=10.0

# 시리얼 포트 설
SERIAL_PORT=COM8
SERIAL_PORT_DESCRIPTION_KEYWORD=USB
# 리부트 후 COM 번호가 바뀌어도 동일 USB 장치를 찾을 때 사용 (GUI 연결 시 자동 저장)
# SERIAL_USB_VID=10C4
# SERIAL_USB_PID=EA60
# SERIAL_USB_SERIAL=

VOLUME_SERIAL_ENABLED=false
VOLUME_SERIAL_PORT=COM10

# WebSocket URL. 수동 시 WEBVIEW_WS_URL.
WS_RECONNECT_INTERVAL=5.0

# 통합 WebView 모드 (Windows 전용)
WEBVIEW_ENABLED=false
# 별도 로컬 웹뷰 WS 서버(화면 URL/원격 재부팅/요청 기반 스크린샷) 설정.
WEBVIEW_WS_URL=wss://hcg.jdone.co.kr/ws/kiosk?device_id=0a5066aa-20cf-4129-8e33-e45bc5e23676
WEBVIEW_DEVTOOLS=true
WEBVIEW_TRAY_ENABLED=true

# 사람 없음 + 입력 유휴 시 자동 도어 닫기 (초)
VACANT_IDLE_CLOSE_SECONDS=20.0

# PCB status 조회 주기 (초). 600 = 10분
STATUS_POLL_INTERVAL=600

# 오른쪽 버튼 Meet/웹 브라우저
# Meet URL은 서버 WebSocket 메시지로 수신
BACKGROUND_BROWSER_TIMEOUT_SECONDS=300

# 테스트 모드: 실제 PCB 없이 가짜 시리얼로 제어·수집 로직을 그대로 돌린다.
TEST_MODE_ENABLED=false

# 로그 레벨 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
