# ysoh 2026-06-13 or KIOSK or POLE_N_ED
#ASSET_DEVICE_TYPE=SMART_POLE
#DEVICE_ID=126763f1-d7bb-4744-a478-8bb98510343a
ASSET_DEVICE_TYPE=KIOSK
DEVICE_ID=e903e889-6c02-4384-84ae-ca8d969540dd


# ysoh 2026-06-14: 송출 URL / 기본 URL / WebSocket
BASE_URL=https://hcg.jdone.co.kr/
DEFAULT_URL=https://hcg.jdone.co.kr
DEVICE_API_BASE_URL=https://hcg.jdone.co.kr
DEVICE_API_TIMEOUT=10.0
WEBSOCKET_ADDR=wss://hcg.jdone.co.kr/api/ws/device

# 시리얼 포트 설
SERIAL_PORT=COM4

VOLUME_SERIAL_PORT=COM3

# WebSocket (백엔드 연동 시 true). device_id 쿼리는 실행 시 자동 추가.
WS_RECONNECT_INTERVAL=5.0

# WebView 옵션
WEBVIEW_DEVTOOLS=true

# 사람 없음 + 입력 유휴 시 자동 도어 닫기 (초, INPUT_MONITOR_ENABLED 필요)
VACANT_IDLE_CLOSE_SECONDS=20.0

INPUT_MONITOR_ENABLED=true

# PCB status 조회 주기 (초). 600 = 10분
STATUS_POLL_INTERVAL=600

# 오른쪽 버튼 Meet/웹 브라우저
# Meet URL은 서버 WebSocket 메시지로 수신
BACKGROUND_BROWSER_TIMEOUT_SECONDS=600

# 로그 레벨 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO